# 复制为 .env 后填写。申请到账号后把 LLM_API_KEY 填上即可联调。

# --- 上游 OpenAI 兼容 API ---
# 官方示例：
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# DEFAULT_MODEL=gpt-4o-mini

# 内网聚合网关示例（仅 chat，无 embeddings 时 RAG 索引需 stub/另配）：
LLM_BASE_URL=http://10.212.129.94:8090/v1
LLM_API_KEY=sk-your-key-here
DEFAULT_MODEL=deepseek-v4-flash
AGENT_MODEL=deepseek-v4-flash
RAG_QUERY_MODEL=deepseek-v4-flash

# 可选：网关对外展示的版本号
APP_VERSION=0.1.0

# RAG（第 2 周）：向量库与 embedding
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=ai_platform_lab
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
RAG_DATA_ROOT=./data/rag
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# RAG 问答（第 3 周）
RAG_MIN_SCORE=0.35
RAG_PROMPT_PATH=./config/rag_prompt.txt
# RAG_QUERY_MODEL=gpt-4o-mini

# Agent（第 4 周，模型须支持 function calling）
AGENT_MAX_STEPS=8
AGENT_TOOL_TIMEOUT_SECONDS=10
AGENT_TOOL_MAX_RETRIES=1
# AGENT_MODEL=gpt-4o-mini
# Phase O #88 — react（默认）| cot（显式 thinking trace）
# AGENT_REASONING_MODE=react

# 观测（第 5 周）
OTEL_ENABLED=false
OTEL_CONSOLE_EXPORT=true
METRICS_ENABLED=true

# 硬化（第 6 周）
MODELS_CONFIG_PATH=./config/models.yaml
DEFAULT_RATE_LIMIT_RPS=20
DEFAULT_RATE_LIMIT_BURST=40

# Phase A — 可内测（Redis 共享状态 + Worker 队列 + 审计）
# 留空则 quota/限流/任务表回退进程内存；索引走 gateway BackgroundTasks
REDIS_URL=redis://127.0.0.1:6379/0
USE_INDEX_WORKER=false
INDEX_QUEUE_NAME=ai_platform:index_queue
AUDIT_ENABLED=true
AUDIT_DB_PATH=./data/audit.db

# Phase B — token 计量与预算（Postgres）
# Compose 默认：postgresql://aiplatform:aiplatform@127.0.0.1:5432/ai_platform_lab
DATABASE_URL=

# Phase B2 — 密钥 / 混合检索 / 可观测
# SECRETS_PROVIDER=env|vault ；路径 tenants/demo-a/bearer → 环境变量 SECRET_TENANTS_DEMO_A_BEARER
SECRETS_PROVIDER=env
# VAULT_ADDR=http://127.0.0.1:8200
# VAULT_TOKEN=dev-only-token
# LLM_SECRET_REF=llm/api_key
# RAG_RETRIEVAL_MODE=vector|hybrid
# OTEL_ENABLED=true
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4317

# Phase B3 — rerank + kb 金丝雀（见 config/rag.yaml kb_routing）
# RAG_RERANK_ENABLED=true
# RAG_RERANK_MODE=api
RAG_RERANK_ENABLED=true
RAG_RERANK_MODE=api
# RAG_RERANK_TOP_N=10
# RAG_RERANK_API_URL=http://127.0.0.1:8200/v1/rerank
# RAG_RERANK_MODEL=bge-reranker-base
# RAG_RERANK_API_KEY=   # 空则回退 LLM_API_KEY

# Phase D — 治理 / 运维 / 金丝雀
# AUTH_JWT_ENABLED=false
# AUTH_JWT_SECRET=
# AUDIT_POSTGRES_ENABLED=true
# CIRCUIT_BREAKER_THRESHOLD=5
# CANARY_AUTO_ROLLBACK_MIN_PASS_RATE=0.85
# CANARY_GUARD_WEBHOOK_URL=              # 回滚时 POST 通知（opt-in）
# CANARY_GUARD_WEBHOOK_SECRET=

# Phase G — 语义缓存 (#34)
# 默认关闭；启用后 gateway 在 /v1/chat/completions 拦截：
#   - exact 模式：SHA256(messages) 精确匹配（无 embedding 也可用）
#   - semantic 模式：embedding 余弦相似度 ≥ 阈值即命中（需 LLM_API_KEY 配合 embedding 服务）
# 命中后在响应体 _platform.cache_hit=true；指标暴露在 /metrics
SEMANTIC_CACHE_ENABLED=false
SEMANTIC_CACHE_MODE=semantic
SEMANTIC_CACHE_SIMILARITY_THRESHOLD=0.92
SEMANTIC_CACHE_TTL_SECONDS=3600
SEMANTIC_CACHE_MAX_ENTRIES_PER_TENANT=256
# 跳过缓存的模型列表（逗号分隔），如 reasoning 模型
SEMANTIC_CACHE_SKIP_MODELS=
# temperature 高于此值的请求跳过缓存（默认 0.3，保证只缓存确定性生成）
SEMANTIC_CACHE_MAX_TEMPERATURE=0.3

# Phase F — Prompt 版本化 (#29)
# 启用后 RAG/Agent 优先从 registry 取 prompt；关闭则回退 legacy txt
PROMPT_REGISTRY_ENABLED=true
PROMPTS_CONFIG_PATH=./config/prompts.yaml
PROMPT_OVERRIDES_PATH=./data/prompt_overrides.json
# API：GET /internal/prompts, POST /internal/prompts/{id}/versions, PATCH /internal/prompts/{id}/active

# Phase F — Prompt A/B 实验 (#30)
# 启用后 RAG query 时按实验分桶取版本；关闭则始终用 active 版本
PROMPT_EXPERIMENT_ENABLED=true
PROMPT_EXPERIMENTS_PATH=./data/prompt_experiments.json
PROMPT_EXPERIMENT_DEFAULT_MIN_SAMPLES=100
PROMPT_EXPERIMENT_DEFAULT_MARGIN=0.1
# API：
#   POST /internal/prompts/{id}/experiments                 创建实验
#   GET  /internal/prompts/{id}/experiments/current         查询当前运行中
#   POST /internal/prompts/{id}/experiments/{exp_id}/stop   停止
#   POST /internal/prompts/{id}/experiments/{exp_id}/promote 提升胜出版本为 active
#   POST /internal/prompts/{id}/experiments/{exp_id}/feedback 记录质量反馈

# Phase F — 长记忆持久化 (#31)
# 启用后 Agent 每 N 轮自动 summarize 历史并持久化（Postgres 主存 / 进程内兜底）
MEMORY_STORE_ENABLED=true
# AGENT_MEMORY_MODEL=gpt-4o-mini      # 摘要使用的模型；未配置则回退到 default_model
MEMORY_SUMMARIZE_EVERY_N_TURNS=8
MEMORY_DEFAULT_TTL_SECONDS=0           # 0 = 不过期
MEMORY_SEARCH_TOP_K=5
# API：
#   POST   /internal/memory                   创建记忆（admin）
#   GET    /internal/memory/{id}              获取单条
#   POST   /internal/memory/search           搜索（按 scope + scope_id + query）
#   GET    /internal/memory/list              列出
#   DELETE /internal/memory/{id}              删除（admin）

# Phase F — 上下文压缩 (#33)
# LLM 增强摘要：用真实 LLM 替换 stub_summarize；失败自动降级 stub
CONTEXT_LLM_SUMMARY_ENABLED=true
# 长记忆注入：Agent 启动时检索 session 长记忆注入 system prompt
CONTEXT_MEMORY_INJECTION_ENABLED=true
CONTEXT_MEMORY_INJECTION_TOP_K=3
CONTEXT_MEMORY_INJECTION_MIN_BUDGET=500    # 剩余 Token 低于此值时跳过注入

# Phase F — MCP 真实集成 (#32)
# 启用后 Agent 动态加载 MCP server 工具；关闭则仅用内置 stub 工具
MCP_ENABLED=true
MCP_SERVERS_CONFIG_PATH=./config/mcp_servers.yaml
MCP_OVERRIDES_PATH=./data/mcp_servers_overrides.json
MCP_CONNECT_TIMEOUT_SECONDS=5
MCP_TOOL_CALL_TIMEOUT_SECONDS=30
# API：
#   GET    /internal/mcp/servers                   列出
#   POST   /internal/mcp/servers                   注册（admin）
#   PATCH  /internal/mcp/servers/{id}              更新（admin）
#   DELETE /internal/mcp/servers/{id}              删除（admin）
#   POST   /internal/mcp/servers/{id}/test         测试连接（admin）
#   GET    /internal/mcp/servers/{id}/tools        列出工具

# Phase O — Plugin Manifest (#90)
# 从 config/plugins/*.yaml 加载轻量 YAML 插件（与 MCP 远程插件互补）
AGENT_PLUGINS_ENABLED=true
AGENT_PLUGINS_CONFIG_DIR=./config/plugins

# Phase O — web_search 工具 (#91)
# mock=确定性假结果（CI 默认）；http=POST 到 WEB_SEARCH_URL
WEB_SEARCH_MODE=mock
WEB_SEARCH_URL=
WEB_SEARCH_TOP_K=3
WEB_SEARCH_MAX_TOP_K=10
WEB_SEARCH_TIMEOUT_SECONDS=10

# Phase H — 控制流编排引擎 (#37)
# DAG + 条件分支 + 循环 + 并行执行
ORCHESTRATOR_ENABLED=true
ORCHESTRATOR_WORKFLOWS_PATH=./config/orchestrator_workflows.yaml
ORCHESTRATOR_OVERRIDES_PATH=./data/orchestrator_overrides.json
ORCHESTRATOR_MAX_STEPS=100
ORCHESTRATOR_TIMEOUT_SECONDS=300
ORCHESTRATOR_MAX_PARALLEL_BRANCHES=5
# API：
#   POST   /internal/orchestrator/workflows                 创建工作流（admin）
#   GET    /internal/orchestrator/workflows                 列出
#   POST   /internal/orchestrator/workflows/{id}/execute    执行

# Phase H — Multi-Agent 协作框架 (#38)
# 主 Agent 委托子 Agent + 并行委托 + 结果聚合
MULTI_AGENT_ENABLED=true
AGENTS_CONFIG_PATH=./config/agents.yaml
AGENTS_OVERRIDES_PATH=./data/agents_overrides.json
MULTI_AGENT_DEFAULT_TIMEOUT=60
MULTI_AGENT_MAX_DEPTH=3
# API：
#   GET    /internal/agents                    列出
#   POST   /internal/agents                    注册（admin）
#   PATCH  /internal/agents/{id}              更新（admin）
#   DELETE /internal/agents/{id}              删除（admin）
#   POST   /internal/agents/{id}/delegate     委托任务

# Phase H — Agent 生命周期管理 (#39)
# 版本注册 + 灰度发布 + 蓝绿切换 + 一键回滚
AGENT_LIFECYCLE_ENABLED=true
AGENT_LIFECYCLE_VERSIONS_PATH=./config/agent_versions.yaml
AGENT_LIFECYCLE_OVERRIDES_PATH=./data/agent_versions_overrides.json
# API：
#   POST /internal/agent-lifecycle/{agent_id}/versions      注册新版本（admin）
#   GET  /internal/agent-lifecycle/{agent_id}/versions     列出版本
#   POST /internal/agent-lifecycle/versions/{id}/activate   激活版本（admin）
#   POST /internal/agent-lifecycle/{agent_id}/rollback     回滚到上一版（admin）
#   GET  /internal/agent-lifecycle/{agent_id}/active       查看激活版本

# Phase H — HITL 完整工作流 (#40)
# 审批队列（DB 存储）+ Webhook 通知 + 超时处理
HITL_ENABLED=true
HITL_STORE_DATABASE_URL=              # None=内存；sqlite:///data/hitl.db 用 SQLite
HITL_DEFAULT_TIMEOUT_SECONDS=300
HITL_WEBHOOK_URL=                     # 审批通知 webhook URL
HITL_WEBHOOK_SECRET=                  # webhook HMAC 签名密钥
HITL_EXPIRY_CHECK_INTERVAL_SECONDS=60
# API：
#   POST   /internal/hitl/approvals              创建审批请求
#   GET    /internal/hitl/approvals              列出（?status=pending）
#   GET    /internal/hitl/approvals/{id}          查看状态
#   POST   /internal/hitl/approvals/{id}/approve  批准（admin）
#   POST   /internal/hitl/approvals/{id}/reject   拒绝（admin）
#   POST   /internal/hitl/approvals/{id}/cancel   取消（admin）

# Phase G — Embedding 独立服务 (#35)
# Provider 抽象 + 模型注册表 + REST API + LRU 缓存
EMBEDDING_SERVICE_ENABLED=true
EMBEDDING_MODELS_CONFIG_PATH=./config/embedding_models.yaml
EMBEDDING_MODELS_OVERRIDES_PATH=./data/embedding_models_overrides.json
EMBEDDING_CACHE_MAX_SIZE=10000
EMBEDDING_DEFAULT_MODEL=text-embedding-3-small
# API：
#   GET    /internal/embeddings/models            列出模型
#   POST   /internal/embeddings/models            注册模型（admin）
#   POST   /internal/embeddings/embed             生成 embeddings
#   GET    /internal/embeddings/cache/stats       缓存统计
#   DELETE /internal/embeddings/cache             清空缓存（admin）

# ============================================================
# Phase I — 安全与合规深化
# ============================================================

# Phase I #41 — 沙箱容器隔离
# Docker seccomp + gVisor 可选；默认关闭
SANDBOX_ENABLED=false
SANDBOX_DEFAULT_RUNTIME=process          # process | docker | gvisor
SANDBOX_DEFAULT_IMAGE=python:3.11-slim
SANDBOX_PROFILES_CONFIG_PATH=./config/sandbox_profiles.yaml
SANDBOX_PROFILES_OVERRIDES_PATH=./data/sandbox_profiles_overrides.json
SANDBOX_DEFAULT_MEMORY_MB=256
SANDBOX_DEFAULT_CPU_LIMIT=0.5
SANDBOX_DEFAULT_TIMEOUT_SECONDS=30
# API：
#   GET    /internal/sandbox/profiles            列出档案
#   POST   /internal/sandbox/profiles            注册档案（admin）
#   POST   /internal/sandbox/execute            在沙箱中执行命令（admin）
#   GET    /internal/sandbox/status             检查 docker/gvisor 可用性

# Phase I #42 — 动作分级审计
# read-only / write / destructive 三级 + 审计日志
AUDIT_ACTIONS_ENABLED=true
AUDIT_ACTIONS_CONFIG_PATH=./config/tool_classifications.yaml
AUDIT_ACTIONS_OVERRIDES_PATH=./data/tool_classifications_overrides.json
AUDIT_ACTIONS_STORE_DATABASE_URL=         # None=内存；sqlite:///data/audit_actions.db
AUDIT_DESTRUCTIVE_REQUIRES_APPROVAL=true   # destructive 动作强制审批
# API：
#   GET  /internal/audit-actions/classifications          列出工具分类
#   POST /internal/audit-actions/classifications          注册分类（admin）
#   POST /internal/audit-actions/classify                 分类工具调用
#   GET  /internal/audit-actions/actions                 列出审计动作
#   GET  /internal/audit-actions/actions/destructive     列出 destructive 动作

# Phase I #43 — PII 脱敏 + 内容安全
# 正则检测 + 脱敏 API（redact/mask/hash/block）
PII_SERVICE_ENABLED=true
PII_PATTERNS_CONFIG_PATH=./config/pii_patterns.yaml
PII_PATTERNS_OVERRIDES_PATH=./data/pii_patterns_overrides.json
PII_SAFETY_KEYWORDS_PATH=./config/safety_keywords.yaml
PII_DEFAULT_POLICY=default                 # default | mask | strict
PII_BLOCK_ON_SAFETY_FAILURE=false
# API：
#   GET  /internal/pii/patterns               列出 PII 模式
#   POST /internal/pii/patterns               注册模式（admin）
#   GET  /internal/pii/policies               列出脱敏策略
#   POST /internal/pii/detect                 检测 PII
#   POST /internal/pii/redact                 脱敏文本
#   POST /internal/pii/safety                 内容安全检查
#   POST /internal/pii/process               完整管道

# Phase I #44 — OAuth2 / mTLS（生产级鉴权）
# 默认关闭，保持 JWT HS256；启用后替换
OAUTH2_ENABLED=false
OAUTH2_CLIENT_ID=
OAUTH2_CLIENT_SECRET=
OAUTH2_AUTHORIZATION_ENDPOINT=
OAUTH2_TOKEN_ENDPOINT=
OAUTH2_USERINFO_ENDPOINT=
OAUTH2_REDIRECT_URI=http://127.0.0.1:8000/internal/auth/oauth2/callback
OAUTH2_SCOPES=openid profile email
OAUTH2_ISSUER=
OAUTH2_JWT_FALLBACK=true                    # OAuth2 失败时回退 JWT
MTLS_ENABLED=false
MTLS_CA_CERT_PATH=
MTLS_SERVER_CERT_PATH=
MTLS_SERVER_KEY_PATH=
MTLS_CLIENT_CERT_REQUIRED=true
# API：
#   GET  /internal/auth/oauth2/authorize      跳转 OAuth2 授权
#   POST /internal/auth/oauth2/callback        处理授权码回调
#   POST /internal/auth/oauth2/refresh         刷新 token
#   GET  /internal/auth/oauth2/userinfo        获取用户信息
#   GET  /internal/auth/mtls/status            检查 mTLS 配置
#   GET  /internal/auth/config                 查看启用的鉴权方式（admin）

# ============================================================
# Phase J — 平台开发者体验
# ============================================================

# Phase J #29 — Python SDK（独立包，无 gateway 配置）
# 安装：cd sdk/python && pip install -e .
# 使用：from ai_platform_lab import Client; c = Client("http://localhost:8000", api_key="...")

# Phase J #30 — Console V2（React 前端）
# 构建：cd console-v2 && npm install && npm run build
# 产物输出到 apps/console/static/，由 FastAPI 托管
# 前端构建时读取 VITE_API_BASE 环境变量

# Phase J #31 — 评测 Pipeline
EVAL_PIPELINE_ENABLED=true
EVAL_GATEWAY_URL=http://127.0.0.1:8000
EVAL_API_KEY=                              # 无则跳过 live 用例
# EVAL_JUDGE_MODEL=deepseek-v4-flash        # llm_judge 打分模型（默认 DEFAULT_MODEL）
EVAL_GATE_THRESHOLD_PCT=5.0               # 门禁阈值
EVAL_BASELINE_PATH=./eval/baselines/main_baseline.json

# ============================================================
# Phase K — 生产基础设施
# ============================================================

# Phase K #33 — 对象存储接入
STORAGE_BACKEND=local                     # local | s3 | oss
STORAGE_BUCKET=ai-platform-lab
STORAGE_PREFIX=
STORAGE_REGION=us-east-1
STORAGE_ENDPOINT=                         # 自定义（OSS/MinIO）
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_LOCAL_ROOT=./data/storage
STORAGE_PRESIGN_EXPIRY_SECONDS=3600
# API：
#   POST   /internal/storage/upload              上传文件
#   GET    /internal/storage/{key}                下载
#   DELETE /internal/storage/{key}                删除（admin）
#   GET    /internal/storage/list?prefix=         列出
#   HEAD   /internal/storage/{key}                检查存在 + metadata
#   POST   /internal/storage/presign/{key}        预签名 URL（admin）

# Phase K #34 — K8s Helm Chart
# 部署：helm install ai-platform-lab deploy/helm/ai-platform-lab/
# 生产：helm install ai-platform-lab deploy/helm/ai-platform-lab/ -f deploy/helm/values-prod.yaml
# 详见 deploy/helm/README.md

# Phase J #32 — 反馈飞轮（反馈采集 + 质量监控 + 飞轮）
FEEDBACK_ENABLED=true
FEEDBACK_STORE_DATABASE_URL=                # None=内存；sqlite:///data/feedback.db
QUALITY_MONITOR_ENABLED=true
QUALITY_MONITOR_WINDOW_SECONDS=300            # 聚合窗口
QUALITY_ALERT_SATISFACTION_THRESHOLD=0.7      # 满意度告警
QUALITY_ALERT_BAD_CASE_THRESHOLD=10           # 差评数告警
FEEDBACK_LOOP_ENABLED=true
FEEDBACK_LOOP_BAD_CASES_PATH=./eval/baselines/bad_cases.jsonl
FEEDBACK_LOOP_AUTO_EXPERIMENT=false           # 自动 A/B 实验（默认关闭）
# API：
#   POST /internal/feedback              记录反馈
#   GET  /internal/feedback/bad-cases    差评列表
#   GET  /internal/quality/current/{tid} 当前质量指标
#   GET  /internal/quality/alerts/{tid} 告警
#   POST /internal/feedback-loop/cycle/{tid}  完整飞轮（admin）

# Phase K #35 — 多 AZ 高可用（部署配置，无 Python 设置）
# 部署：helm install ai-platform-lab deploy/helm/ai-platform-lab/ -f deploy/helm/values-multi-az.yaml
# 含：Qdrant 副本 + Redis Sentinel + Postgres streaming + PDB + NetworkPolicy

# Phase K #36 — GPU 弹性调度（部署配置，无 Python 设置）
# 部署：helm install ai-platform-lab deploy/helm/ai-platform-lab/ -f deploy/helm/values-gpu.yaml
# 含：Embedding/Rerank GPU Deployment + HPA（CPU+GPU+QPS）+ 模型预热
