# 复制为 .env 后填写。申请到账号后把 LLM_API_KEY 填上即可联调。

# 上游 OpenAI 兼容 API（示例：官方、聚合网关、自建 vLLM）
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=

# 未指定模型时的默认名（需与上游可用模型一致）
DEFAULT_MODEL=gpt-4o-mini

# 可选：网关对外展示的版本号
APP_VERSION=0.1.0

# RAG（第 2 周）：向量库与 embedding
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=ai_platform_lab
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
RAG_DATA_ROOT=./data/rag
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# RAG 问答（第 3 周）
RAG_MIN_SCORE=0.35
RAG_PROMPT_PATH=./config/rag_prompt.txt
# RAG_QUERY_MODEL=gpt-4o-mini

# Agent（第 4 周，模型须支持 function calling）
AGENT_MAX_STEPS=8
AGENT_TOOL_TIMEOUT_SECONDS=10
AGENT_TOOL_MAX_RETRIES=1
# AGENT_MODEL=gpt-4o-mini

# 观测（第 5 周）
OTEL_ENABLED=false
OTEL_CONSOLE_EXPORT=true
METRICS_ENABLED=true

# 硬化（第 6 周）
MODELS_CONFIG_PATH=./config/models.yaml
DEFAULT_RATE_LIMIT_RPS=20
DEFAULT_RATE_LIMIT_BURST=40

# Phase A — 可内测（Redis 共享状态 + Worker 队列 + 审计）
# 留空则 quota/限流/任务表回退进程内存；索引走 gateway BackgroundTasks
REDIS_URL=redis://127.0.0.1:6379/0
USE_INDEX_WORKER=false
INDEX_QUEUE_NAME=ai_platform:index_queue
AUDIT_ENABLED=true
AUDIT_DB_PATH=./data/audit.db

# Phase B — token 计量与预算（Postgres）
# Compose 默认：postgresql://aiplatform:aiplatform@127.0.0.1:5432/ai_platform_lab
DATABASE_URL=
