[project.optional-dependencies]
dev = [
  "ruff>=0.8.1",
  "pytest>=8.0",
  "mypy>=1.8",
  "pre-commit>=3.0",
]

[tool.ruff]
line-length = 100
target-version = "py311"

[tool.ruff.lint]
select = ["E", "F", "I", "UP"]
ignore = ["E501"]

[tool.mypy]
python_version = "3.11"
warn_unused_configs = true
show_error_codes = true

[[tool.mypy.overrides]]
module = "<module>.*"
ignore_errors = false

[[tool.mypy.overrides]]
module = ["tests.*", "scripts.*"]
ignore_errors = true
