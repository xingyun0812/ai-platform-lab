{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "gateway",
      "runtimeExecutable": "uvicorn",
      "runtimeArgs": [
        "apps.gateway.main:app",
        "--host",
        "127.0.0.1",
        "--port",
        "8000"
      ],
      "port": 8000
    },
    {
      "name": "console-v2",
      "runtimeExecutable": "npx",
      "runtimeArgs": [
        "vite",
        "--config",
        "console-v2/vite.config.ts"
      ],
      "port": 5173
    },
    {
      "name": "worker",
      "runtimeExecutable": "python",
      "runtimeArgs": [
        "apps/worker/main.py"
      ],
      "port": null
    }
  ]
}
